# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Marketing & analytics (see docs/ANALYTICS.md for full event list) ───

# Google Tag Manager — e.g. GTM-XXXXXXX (tagmanager.google.com)
# When set, GA4/Meta load via GTM only (import gtm/prestoliv-analytics-import.json).
VITE_GTM_ID=

# Google Analytics 4 — only if NOT using GTM (leave empty when VITE_GTM_ID is set)
VITE_GA_MEASUREMENT_ID=

# Meta Pixel — numeric ID (business.facebook.com → Events Manager)
VITE_META_PIXEL_ID=

# Microsoft Clarity — project ID (clarity.microsoft.com)
VITE_CLARITY_PROJECT_ID=

# Client dashboard (default: https://dashboard.prestoliv.com)
VITE_DASHBOARD_URL=https://dashboard.prestoliv.com
